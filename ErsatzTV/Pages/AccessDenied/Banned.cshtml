@page "/access-denied/banned"
@model ErsatzTV.Pages.AccessDenied.BannedModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    @await Html.PartialAsync("../../Shared/_AntiIndexingHead")
    <title>ErsatzTV Legacy - IP Banned</title>
    <link href="/css/site.css" asp-append-version="true" rel="stylesheet"/>
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #272727;
            color: rgba(255, 255, 255, 0.9);
            font-family: Roboto, Helvetica, Arial, sans-serif;
        }

        .gate-card {
            width: 100%;
            max-width: 480px;
            padding: 2.5rem 2rem;
            border-radius: 8px;
            background: #1f1f1f;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
            text-align: center;
        }

        .gate-card img {
            display: block;
            margin: 0 auto 1.5rem;
            max-width: 160px;
        }

        .gate-card h1 {
            margin: 0 0 1rem;
            font-size: 1.5rem;
        }

        .gate-card p {
            margin: 0;
            color: rgba(255, 255, 255, 0.65);
            line-height: 1.5;
        }

        .ip-label {
            margin-top: 1.25rem;
            font-size: 0.875rem;
            color: rgba(255, 255, 255, 0.45);
        }
    </style>
</head>
<body>
<div class="gate-card">
    <img src="/images/ersatztv.png?v=2" alt="ErsatzTV"/>
    <h1>This IP Address Has Been Banned</h1>
    <p>Access to the Admin Portal from your network is not permitted.</p>
    @if (!string.IsNullOrWhiteSpace(Model.IpDisplay))
    {
        <p class="ip-label">@Model.IpDisplay</p>
    }
</div>
</body>
</html>
