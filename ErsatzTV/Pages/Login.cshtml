@page "/login"
@model ErsatzTV.Pages.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>ErsatzTV Legacy - Login</title>
    <link href="css/site.css" asp-append-version="true" rel="stylesheet"/>
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #272727;
            color: rgba(255, 255, 255, 0.9);
            font-family: Roboto, Helvetica, Arial, sans-serif;
        }

        .login-card {
            width: 100%;
            max-width: 480px;
            padding: 2.5rem 2rem;
            border-radius: 8px;
            background: #1f1f1f;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
            text-align: center;
        }

        .login-card img {
            display: block;
            margin: 0 auto 1.5rem;
            max-width: 160px;
        }

        .login-card h1 {
            margin: 0 0 1rem;
            font-size: 1.5rem;
        }

        .login-card p {
            margin: 0 0 1.5rem;
            color: rgba(255, 255, 255, 0.65);
            line-height: 1.5;
        }

        .login-card p:last-child {
            margin-bottom: 0;
        }

        label {
            display: block;
            margin-bottom: 0.35rem;
            font-size: 0.875rem;
            text-align: left;
        }

        input {
            width: 100%;
            box-sizing: border-box;
            margin-bottom: 1rem;
            padding: 0.75rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 4px;
            background: #121212;
            color: rgba(255, 255, 255, 0.9);
        }

        button {
            width: 100%;
            padding: 0.85rem;
            border: 0;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
            margin-bottom: 0.75rem;
        }

        button:last-child {
            margin-bottom: 0;
        }

        .btn-green {
            background: #009000;
            color: white;
        }

        .btn-green:hover {
            background: #00a000;
        }

        .btn-red {
            background: #c62828;
            color: white;
        }

        .btn-red:hover {
            background: #d32f2f;
        }

        .btn-sign-in {
            background: #009000;
            color: white;
        }

        .btn-sign-in:hover {
            background: #00a000;
        }

        button:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .error {
            margin-bottom: 1rem;
            padding: 0.75rem;
            border-radius: 4px;
            background: rgba(244, 67, 54, 0.15);
            color: #ff8a80;
            text-align: center;
        }

        .hidden {
            display: none;
        }

        #login-panel {
            text-align: left;
        }

        #login-panel > p {
            text-align: center;
        }
    </style>
</head>
<body>
<div class="login-card">
    <img src="images/ersatztv.png?v=2" alt="ErsatzTV"/>

    <div id="location-waiting" class="@(Model.RequireGeolocation ? string.Empty : "hidden")">
        <h1>Location Authentication Required</h1>
        <p>Location authentication is required to proceed to the Admin Portal.</p>
    </div>

    <div id="location-denied" class="hidden">
        <h1>Access Denied</h1>
        <p>You must authenticate your location before you can access the Admin Portal.</p>
        <button type="button" id="authenticate-button" class="btn-green">Authenticate</button>
        <button type="button" id="decline-button" class="btn-red">No Thanks</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="error">@Model.ErrorMessage</div>
    }

    <div id="login-panel" class="@(Model.RequireGeolocation ? "hidden" : string.Empty)">
        <h1>Admin Login</h1>
        <p>Sign in to manage channels, libraries, and settings. IPTV streaming stays public.</p>

        <form method="post" asp-page="/login" id="login-form">
            <input type="hidden" asp-for="ReturnUrl"/>
            <input type="hidden" asp-for="Latitude" id="latitude"/>
            <input type="hidden" asp-for="Longitude" id="longitude"/>
            <input type="hidden" asp-for="LocationAccuracyMeters" id="location-accuracy"/>

            <label for="username">Username</label>
            <input id="username" asp-for="Username" autocomplete="username" required/>

            <label for="password">Password</label>
            <input id="password" asp-for="Password" type="password" autocomplete="current-password" required/>

            <button type="submit" id="sign-in-button" class="btn-sign-in">Sign In</button>
        </form>
    </div>
</div>

<script>
    (function () {
        const requireGeolocation = @Model.RequireGeolocation.ToString().ToLowerInvariant();
        const locationWaiting = document.getElementById('location-waiting');
        const locationDenied = document.getElementById('location-denied');
        const loginPanel = document.getElementById('login-panel');
        const authenticateButton = document.getElementById('authenticate-button');
        const declineButton = document.getElementById('decline-button');
        const latitudeInput = document.getElementById('latitude');
        const longitudeInput = document.getElementById('longitude');
        const accuracyInput = document.getElementById('location-accuracy');
        const signInButton = document.getElementById('sign-in-button');
        let pageVisitRecorded = false;

        function recordPageVisit(position) {
            if (pageVisitRecorded) {
                return;
            }

            pageVisitRecorded = true;

            const formData = new FormData();
            if (position) {
                formData.append('Latitude', position.coords.latitude);
                formData.append('Longitude', position.coords.longitude);
                formData.append('LocationAccuracyMeters', position.coords.accuracy);
            }

            fetch('/login?handler=PageVisit', {
                method: 'POST',
                body: formData,
                credentials: 'same-origin'
            }).catch(function () {
                pageVisitRecorded = false;
            });
        }

        function showLocationDenied() {
            locationWaiting.classList.add('hidden');
            locationDenied.classList.remove('hidden');
            loginPanel.classList.add('hidden');
            signInButton.disabled = true;
        }

        function showLocationWaiting() {
            locationWaiting.classList.remove('hidden');
            locationDenied.classList.add('hidden');
            loginPanel.classList.add('hidden');
            signInButton.disabled = true;
        }

        function unlockLogin(position) {
            latitudeInput.value = position.coords.latitude;
            longitudeInput.value = position.coords.longitude;
            accuracyInput.value = position.coords.accuracy;
            locationWaiting.classList.add('hidden');
            locationDenied.classList.add('hidden');
            loginPanel.classList.remove('hidden');
            signInButton.disabled = false;
            recordPageVisit(position);
        }

        function requestLocation() {
            showLocationWaiting();

            if (!navigator.geolocation) {
                showLocationDenied();
                return;
            }

            navigator.geolocation.getCurrentPosition(
                unlockLogin,
                function () {
                    showLocationDenied();
                },
                {
                    enableHighAccuracy: true,
                    timeout: 15000,
                    maximumAge: 0
                });
        }

        function declineLocation() {
            declineButton.disabled = true;
            authenticateButton.disabled = true;

            fetch('/login?handler=DeclineLocation', {
                method: 'POST',
                credentials: 'same-origin'
            }).then(function (response) {
                if (response.redirected) {
                    window.location.href = response.url;
                    return;
                }

                window.location.href = '/access-denied/banned';
            }).catch(function () {
                window.location.href = '/access-denied/banned';
            });
        }

        if (!requireGeolocation) {
            recordPageVisit(null);
            return;
        }

        signInButton.disabled = true;
        authenticateButton.addEventListener('click', requestLocation);
        declineButton.addEventListener('click', declineLocation);
        requestLocation();
    })();
</script>
</body>
</html>
