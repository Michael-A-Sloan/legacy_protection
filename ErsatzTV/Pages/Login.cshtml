@page "/login"
@model ErsatzTV.Pages.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>ErsatzTV Legacy - Login</title>
    <link href="css/site.css" asp-append-version="true" rel="stylesheet"/>
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #272727;
            color: rgba(255, 255, 255, 0.9);
            font-family: Roboto, Helvetica, Arial, sans-serif;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            padding: 2rem;
            border-radius: 8px;
            background: #1f1f1f;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
        }

        .login-card img {
            display: block;
            margin: 0 auto 1.5rem;
            max-width: 180px;
        }

        .login-card h1 {
            margin: 0 0 0.5rem;
            font-size: 1.5rem;
            text-align: center;
        }

        .login-card p {
            margin: 0 0 1.5rem;
            text-align: center;
            color: rgba(255, 255, 255, 0.65);
        }

        label {
            display: block;
            margin-bottom: 0.35rem;
            font-size: 0.875rem;
        }

        input {
            width: 100%;
            box-sizing: border-box;
            margin-bottom: 1rem;
            padding: 0.75rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 4px;
            background: #121212;
            color: rgba(255, 255, 255, 0.9);
        }

        button {
            width: 100%;
            padding: 0.75rem;
            border: 0;
            border-radius: 4px;
            background: #009000;
            color: white;
            font-size: 1rem;
            cursor: pointer;
        }

        button:hover {
            background: #00a000;
        }

        .error {
            margin-bottom: 1rem;
            padding: 0.75rem;
            border-radius: 4px;
            background: rgba(244, 67, 54, 0.15);
            color: #ff8a80;
            text-align: center;
        }
    </style>
</head>
<body>
<div class="login-card">
    <img src="images/ersatztv.png?v=2" alt="ErsatzTV"/>
    <h1>Admin Login</h1>
    <p>Sign in to manage channels, libraries, and settings. IPTV streaming stays public.</p>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="error">@Model.ErrorMessage</div>
    }

    <form method="post" asp-page="/login">
        <input type="hidden" asp-for="ReturnUrl"/>
        <label for="username">Username</label>
        <input id="username" asp-for="Username" autocomplete="username" required/>

        <label for="password">Password</label>
        <input id="password" asp-for="Password" type="password" autocomplete="current-password" required/>

        <button type="submit">Sign In</button>
    </form>
</div>
</body>
</html>
