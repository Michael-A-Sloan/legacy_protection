@page "/login"
@model ErsatzTV.Pages.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>ErsatzTV Legacy - Login</title>
    <link href="css/site.css" asp-append-version="true" rel="stylesheet"/>
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #272727;
            color: rgba(255, 255, 255, 0.9);
            font-family: Roboto, Helvetica, Arial, sans-serif;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            padding: 2rem;
            border-radius: 8px;
            background: #1f1f1f;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
        }

        .login-card img {
            display: block;
            margin: 0 auto 1.5rem;
            max-width: 180px;
        }

        .login-card h1 {
            margin: 0 0 0.5rem;
            font-size: 1.5rem;
            text-align: center;
        }

        .login-card p {
            margin: 0 0 1.5rem;
            text-align: center;
            color: rgba(255, 255, 255, 0.65);
        }

        label {
            display: block;
            margin-bottom: 0.35rem;
            font-size: 0.875rem;
        }

        input {
            width: 100%;
            box-sizing: border-box;
            margin-bottom: 1rem;
            padding: 0.75rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 4px;
            background: #121212;
            color: rgba(255, 255, 255, 0.9);
        }

        button {
            width: 100%;
            padding: 0.75rem;
            border: 0;
            border-radius: 4px;
            background: #009000;
            color: white;
            font-size: 1rem;
            cursor: pointer;
        }

        button:hover {
            background: #00a000;
        }

        button.secondary {
            background: #424242;
        }

        button.secondary:hover {
            background: #616161;
        }

        button:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .error {
            margin-bottom: 1rem;
            padding: 0.75rem;
            border-radius: 4px;
            background: rgba(244, 67, 54, 0.15);
            color: #ff8a80;
            text-align: center;
        }

        .hidden {
            display: none;
        }
    </style>
</head>
<body>
<div class="login-card">
    <img src="images/ersatztv.png?v=2" alt="ErsatzTV"/>
    <h1>Admin Login</h1>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="error">@Model.ErrorMessage</div>
    }

    @if (Model.RequireGeolocation)
    {
        <div id="location-gate">
            <p>Browser location access is required before you can sign in. Visits and login attempts are recorded with your coordinates when available.</p>
            <button type="button" id="request-location" class="secondary">Allow Location Access</button>
            <p id="location-status" class="hidden"></p>
        </div>
    }

    <div id="login-panel" class="@(Model.RequireGeolocation ? "hidden" : string.Empty)">
        <p>Sign in to manage channels, libraries, and settings. IPTV streaming stays public.</p>

        <form method="post" asp-page="/login" id="login-form">
            <input type="hidden" asp-for="ReturnUrl"/>
            <input type="hidden" asp-for="Latitude" id="latitude"/>
            <input type="hidden" asp-for="Longitude" id="longitude"/>
            <input type="hidden" asp-for="LocationAccuracyMeters" id="location-accuracy"/>

            <label for="username">Username</label>
            <input id="username" asp-for="Username" autocomplete="username" required/>

            <label for="password">Password</label>
            <input id="password" asp-for="Password" type="password" autocomplete="current-password" required/>

            <button type="submit" id="sign-in-button">Sign In</button>
        </form>
    </div>
</div>

<script>
    (function () {
        const requireGeolocation = @Model.RequireGeolocation.ToString().ToLowerInvariant();
        const gate = document.getElementById('location-gate');
        const loginPanel = document.getElementById('login-panel');
        const requestButton = document.getElementById('request-location');
        const status = document.getElementById('location-status');
        const latitudeInput = document.getElementById('latitude');
        const longitudeInput = document.getElementById('longitude');
        const accuracyInput = document.getElementById('location-accuracy');
        const signInButton = document.getElementById('sign-in-button');
        let pageVisitRecorded = false;

        function recordPageVisit(position) {
            if (pageVisitRecorded) {
                return;
            }

            pageVisitRecorded = true;

            const formData = new FormData();
            if (position) {
                formData.append('Latitude', position.coords.latitude);
                formData.append('Longitude', position.coords.longitude);
                formData.append('LocationAccuracyMeters', position.coords.accuracy);
            }

            fetch('/login?handler=PageVisit', {
                method: 'POST',
                body: formData,
                credentials: 'same-origin'
            }).catch(function () {
                pageVisitRecorded = false;
            });
        }

        function showError(message) {
            status.textContent = message;
            status.className = 'error';
            status.classList.remove('hidden');
            requestButton.disabled = false;
        }

        function unlockLogin(position) {
            latitudeInput.value = position.coords.latitude;
            longitudeInput.value = position.coords.longitude;
            accuracyInput.value = position.coords.accuracy;
            gate.classList.add('hidden');
            loginPanel.classList.remove('hidden');
            signInButton.disabled = false;
            recordPageVisit(position);
        }

        if (!requireGeolocation) {
            recordPageVisit(null);
            return;
        }

        if (!navigator.geolocation) {
            showError('This browser does not support location access. Use HTTPS or a modern browser to sign in.');
            return;
        }

        signInButton.disabled = true;

        requestButton.addEventListener('click', function () {
            requestButton.disabled = true;
            status.classList.add('hidden');

            navigator.geolocation.getCurrentPosition(
                unlockLogin,
                function (error) {
                    let message = 'Location access is required to sign in.';
                    if (error.code === error.PERMISSION_DENIED) {
                        message = 'Location permission was denied. Allow location access for this site and try again.';
                    } else if (error.code === error.POSITION_UNAVAILABLE) {
                        message = 'Location is unavailable. Check your device settings and try again.';
                    } else if (error.code === error.TIMEOUT) {
                        message = 'Location request timed out. Try again.';
                    }

                    showError(message);
                },
                {
                    enableHighAccuracy: true,
                    timeout: 15000,
                    maximumAge: 0
                });
        });
    })();
</script>
</body>
</html>
