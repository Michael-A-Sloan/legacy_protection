@page "/settings/login-ip"
@using System.Globalization
@using ErsatzTV.Application.Configuration
@using ErsatzTV.Application.Security
@using ErsatzTV.Core.Domain
@using ErsatzTV.Core.Domain.Security
@using ErsatzTV.Core.Networking
@using ErsatzTV.Core.Security
@implements IDisposable
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject ILogger<LoginIpSettings> Logger

<MudForm Style="max-height: 100%">
    <MudPaper Square="true" Style="display: flex; height: 64px; min-height: 64px; width: 100%; z-index: 100; align-items: center">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(_ => SaveSettings())" Class="ml-6" StartIcon="@Icons.Material.Filled.Save">Save Settings</MudButton>
    </MudPaper>
    <div class="d-flex flex-column" style="height: 100vh; overflow-x: auto">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-8">
            <MudText Typo="Typo.h5" Class="mb-2">Login IP</MudText>
            <MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">
                Rate limit failed logins, ban or whitelist IP addresses, and review login attempts. IPTV streaming is not affected.
                Localhost, this server's network addresses, and the IP configured in ETV_BASE_URL cannot be banned.
                Local addresses (127.0.0.1, ::1, 0.0.0.0) are also always exempt so library scans and other internal services keep working.
            </MudText>
            <MudDivider Class="mb-6"/>

            <MudText Typo="Typo.h6" Class="mb-4">Rate Limiting</MudText>
            <MudStack Row="true" Breakpoint="Breakpoint.SmAndDown" Class="form-field-stack gap-md-8 mb-5">
                <MudText>Enable Rate Limiting</MudText>
                <MudSwitch @bind-Value="_settings.RateLimitEnabled" Color="Color.Primary"/>
            </MudStack>
            <MudStack Row="true" Breakpoint="Breakpoint.SmAndDown" Class="form-field-stack gap-md-8 mb-5">
                <MudText>Max Failed Attempts</MudText>
                <MudNumericField @bind-Value="_settings.MaxFailedAttempts" Min="1" Max="100" Style="max-width: 200px"/>
            </MudStack>
            <MudStack Row="true" Breakpoint="Breakpoint.SmAndDown" Class="form-field-stack gap-md-8 mb-5">
                <MudText>Window (seconds)</MudText>
                <MudNumericField @bind-Value="_settings.WindowSeconds" Min="60" Max="86400" Style="max-width: 200px"/>
            </MudStack>
            <MudStack Row="true" Breakpoint="Breakpoint.SmAndDown" Class="form-field-stack gap-md-8 mb-8">
                <MudText>Lockout (seconds)</MudText>
                <MudNumericField @bind-Value="_settings.LockoutSeconds" Min="60" Max="86400" Style="max-width: 200px"/>
            </MudStack>

            <MudDivider Class="mb-6"/>
            @if (!_settings.GeolocationRequiredFromEnvironment)
            {
                <MudText Typo="Typo.h6" Class="mb-4">Browser Location</MudText>
                <MudStack Row="true" Breakpoint="Breakpoint.SmAndDown" Class="form-field-stack gap-md-8 mb-5">
                    <MudText>Require Location on Login Page</MudText>
                    <MudSwitch @bind-Value="_settings.GeolocationRequired" Color="Color.Primary"/>
                </MudStack>
                <MudText Typo="Typo.body2" Class="mb-8 mud-text-secondary">
                    When enabled, the browser must grant location access before the login form appears.
                    Coordinates are stored with login attempts. HTTPS is required for location access in most browsers.
                </MudText>
                <MudDivider Class="mb-6"/>
            }

            <MudText Typo="Typo.h6" Class="mb-4">VPN / Proxy Blocking</MudText>
            <MudText Typo="Typo.body2" Class="mb-8 mud-text-secondary">
                Set <code>ETV_BLOCK_VPN=1</code> to block VPN, proxy, and Tor addresses from the admin UI and login page.
                IPTV streaming is not affected. Recommended: sign up at
                <MudLink Href="https://vpnapi.io" Target="_blank">vpnapi.io</MudLink> and set
                <code>ETV_VPNAPI_KEY</code> (free tier: 1,000 lookups/day; results are cached for 6 hours).
                Optional fallback: MaxMind GeoIP Anonymous IP <code>.mmdb</code> via
                <code>ETV_ANONYMOUS_IP_DATABASE</code>. Set <code>ETV_BLOCK_VPN_RELAY=1</code> to also block
                iCloud Private Relay. Set <code>ETV_LOGIN_GEOLOCATION_REQUIRED=1</code> to always require browser
                location on login.
            </MudText>

            <MudDivider Class="mb-6"/>
            <MudText Typo="Typo.h6" Class="mb-4">AbuseIPDB Blocking</MudText>
            @if (_settings.AbuseIpDbAvailable)
            {
                <MudStack Row="true" Breakpoint="Breakpoint.SmAndDown" Class="form-field-stack gap-md-8 mb-5">
                    <MudText>Block Abusive IPs</MudText>
                    <MudSwitch @bind-Value="_settings.AbuseIpDbBlockEnabled" Color="Color.Primary"/>
                </MudStack>
                <MudStack Row="true" Breakpoint="Breakpoint.SmAndDown" Class="form-field-stack gap-md-8 mb-5">
                    <MudText>Minimum Abuse Score</MudText>
                    <MudNumericField @bind-Value="_settings.AbuseIpDbMinScore" Min="0" Max="100" Style="max-width: 200px"/>
                </MudStack>
                <MudText Typo="Typo.body2" Class="mb-8 mud-text-secondary">
                    Blocks admin UI access when AbuseIPDB reports an abuse confidence score at or above the threshold.
                    IPTV streaming is not affected. Results are cached for 6 hours. Click <strong>AbuseIPDB</strong> on
                    any IP below to view the full report.
                </MudText>
            }
            else
            {
                <MudText Typo="Typo.body2" Class="mb-8 mud-text-secondary">
                    Set <code>ETV_ABUSEIPDB_ENABLED=1</code> and <code>ETV_ABUSEIPDB_API_KEY</code> from your
                    <MudLink Href="https://www.abuseipdb.com/" Target="_blank">AbuseIPDB</MudLink> account to enable
                    abusive IP blocking for the admin UI. Optional: <code>ETV_ABUSEIPDB_MIN_SCORE</code> (default 75),
                    <code>ETV_ABUSEIPDB_MAX_AGE_DAYS</code> (default 90).
                </MudText>
            }

            <MudDivider Class="mb-6"/>
            <MudText Typo="Typo.h6" Class="mb-4">Public Blocklists</MudText>
            <MudStack Row="true" Breakpoint="Breakpoint.SmAndDown" Class="form-field-stack gap-md-8 mb-5">
                <MudText>Block Public Blocklists</MudText>
                <MudSwitch @bind-Value="_settings.PublicBlocklistsMasterEnabled" Color="Color.Primary"/>
            </MudStack>
            <MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">
                Automatically downloads open-source IP blocklists from GitHub and blocks matching addresses from the admin UI.
                You can also add your own list URLs below. IPTV streaming is not affected. Lists refresh on their own schedule in the background.
            </MudText>
            <MudStack Row="true" Spacing="2" Class="mb-4">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@EnableRecommendedBlocklists">Enable Recommended</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="@RefreshPublicBlocklists" Disabled="@_refreshingBlocklists">
                    @(_refreshingBlocklists ? "Refreshing..." : "Refresh All Now")
                </MudButton>
            </MudStack>
            <MudTable Items="@_settings.PublicBlocklists" Dense="true" Class="mb-8" Hover="true">
                <HeaderContent>
                    <MudTh>On</MudTh>
                    <MudTh>List</MudTh>
                    <MudTh>Category</MudTh>
                    <MudTh>Entries</MudTh>
                    <MudTh>Last Updated</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudSwitch @bind-Value="context.Enabled" Color="Color.Primary"/>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2">@context.Name</MudText>
                        @if (context.Recommended)
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small" Class="mt-1">Recommended</MudChip>
                        }
                        @if (context.IsCustom)
                        {
                            <MudChip T="string" Color="Color.Info" Size="Size.Small" Class="mt-1">Custom</MudChip>
                        }
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.SourceLabel</MudText>
                        @if (context.IsCustom)
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.SourceUrl</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                Updates every @context.UpdateIntervalHours h · @FormatBlocklistFormat(context.Format)
                            </MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Description</MudText>
                        }
                    </MudTd>
                    <MudTd>@context.Category</MudTd>
                    <MudTd>@FormatBlocklistEntries(context)</MudTd>
                    <MudTd>@FormatBlocklistUpdated(context.LastUpdatedUtc)</MudTd>
                    <MudTd>@FormatBlocklistStatus(context)</MudTd>
                    <MudTd>
                        @if (context.IsCustom)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                           OnClick="@(_ => RemoveCustomBlocklist(context.Id))"/>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <MudText Typo="Typo.subtitle1" Class="mb-2">Add Custom Blocklist</MudText>
            <MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">
                Paste a direct link to a plain-text IP list (one IP or CIDR per line). The list will download automatically on save and refresh on your chosen interval.
            </MudText>
            <MudStack Row="true" Spacing="2" Class="mb-8" Wrap="Wrap.Wrap">
                <MudTextField @bind-Value="_newCustomBlocklistName" Label="Name" Style="max-width: 220px"/>
                <MudTextField @bind-Value="_newCustomBlocklistUrl" Label="List URL" Style="min-width: 320px; flex: 1"/>
                <MudSelect T="PublicBlocklistFormat" @bind-Value="_newCustomBlocklistFormat" Label="Format" Style="max-width: 180px">
                    <MudSelectItem T="PublicBlocklistFormat" Value="PublicBlocklistFormat.Mixed">IPs and CIDRs</MudSelectItem>
                    <MudSelectItem T="PublicBlocklistFormat" Value="PublicBlocklistFormat.IpAddress">IPs only</MudSelectItem>
                </MudSelect>
                <MudNumericField @bind-Value="_newCustomBlocklistUpdateHours" Label="Update every (hours)" Min="1" Max="168" Style="max-width: 200px"/>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@AddCustomBlocklist">Add List</MudButton>
            </MudStack>

            <MudDivider Class="mb-6"/>
            <MudText Typo="Typo.h6" Class="mb-4">Whitelist</MudText>
            <MudStack Row="true" Breakpoint="Breakpoint.SmAndDown" Class="form-field-stack gap-md-8 mb-5">
                <MudText>Enable Whitelist</MudText>
                <MudSwitch @bind-Value="_settings.WhitelistEnabled" Color="Color.Primary"/>
            </MudStack>
            <MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">
                When enabled and at least one IP is listed, only whitelisted addresses can sign in.
            </MudText>
            <MudStack Row="true" Spacing="2" Class="mb-4">
                <MudTextField @bind-Value="_newWhitelistIp" Label="IP Address" Style="max-width: 220px"/>
                <MudTextField @bind-Value="_newWhitelistNote" Label="Note" Style="max-width: 280px"/>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(_ => AddRule(AdminIpRuleType.Whitelist))">Add to Whitelist</MudButton>
            </MudStack>
            <MudTable Items="@_whitelistRules" Dense="true" Class="mb-8">
                <HeaderContent>
                    <MudTh>IPv4</MudTh>
                    <MudTh>IPv6</MudTh>
                    <MudTh>Note</MudTh>
                    <MudTh>Added</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@FormatIp(context.IpAddressV4)</MudTd>
                    <MudTd>@FormatIp(context.IpAddressV6)</MudTd>
                    <MudTd>@context.Note</MudTd>
                    <MudTd>@context.CreatedAt.ToLocalTime().ToString("g", _dtf)</MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(_ => RemoveRule(context.Id))"/>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText>No whitelisted IP addresses.</MudText>
                </NoRecordsContent>
            </MudTable>

            <MudDivider Class="mb-6"/>
            <MudText Typo="Typo.h6" Class="mb-4">Banned IPs</MudText>
            <MudStack Row="true" Breakpoint="Breakpoint.SmAndDown" Class="form-field-stack gap-md-8 mb-5">
                <MudText>Enable Blacklist</MudText>
                <MudSwitch @bind-Value="_settings.BlacklistEnabled" Color="Color.Primary"/>
            </MudStack>
            <MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">
                Banned addresses keep trying in the background. Activity counts appear here and in Banned IP Activity below, not in the main login log.
            </MudText>
            <MudStack Row="true" Spacing="2" Class="mb-4">
                <MudTextField @bind-Value="_newBlacklistIp" Label="IP Address" Style="max-width: 220px"/>
                <MudTextField @bind-Value="_newBlacklistNote" Label="Note" Style="max-width: 280px"/>
                <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="@(_ => AddRule(AdminIpRuleType.Blacklist))">Ban IP</MudButton>
            </MudStack>
            <MudTable Items="@_blacklistRules" Dense="true" Class="mb-4">
                <HeaderContent>
                    <MudTh>IPv4</MudTh>
                    <MudTh>IPv6</MudTh>
                    <MudTh>Note</MudTh>
                    <MudTh>Views</MudTh>
                    <MudTh>Logins</MudTh>
                    <MudTh>Access</MudTh>
                    <MudTh>Total</MudTh>
                    <MudTh>Last Seen</MudTh>
                    <MudTh>Banned</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@FormatIp(context.IpAddressV4)</MudTd>
                    <MudTd>@FormatIp(context.IpAddressV6)</MudTd>
                    <MudTd>@context.Note</MudTd>
                    <MudTd>@context.PageViewCount</MudTd>
                    <MudTd>@context.LoginAttemptCount</MudTd>
                    <MudTd>@context.AccessDeniedCount</MudTd>
                    <MudTd>@context.TotalActivityCount</MudTd>
                    <MudTd>@FormatLastActivity(context.LastActivityAt)</MudTd>
                    <MudTd>@context.CreatedAt.ToLocalTime().ToString("g", _dtf)</MudTd>
                    <MudTd>
                        <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small"
                                   OnClick="@(_ => ShowBannedActivity(context.IpAddress))">Activity</MudButton>
                        @if (_settings.AbuseIpDbAvailable)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small"
                                       OnClick="@(_ => ShowAbuseIpDbReport(context.IpAddress))">AbuseIPDB</MudButton>
                        }
                        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(_ => Unban(context.IpAddress))">Unban</MudButton>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText>No banned IP addresses.</MudText>
                </NoRecordsContent>
            </MudTable>

            <MudText Typo="Typo.subtitle1" Class="mb-2">Banned IP Activity</MudText>
            <MudStack Row="true" Spacing="2" Class="mb-4">
                <MudSelect T="string" @bind-Value="_bannedIpFilter" Label="Filter by banned IP" Style="max-width: 280px" Clearable="true">
                    @foreach (AdminIpRuleViewModel rule in _blacklistRules)
                    {
                        <MudSelectItem T="string" Value="@rule.IpAddress">@FormatIp(rule.IpAddressV4) / @FormatIp(rule.IpAddressV6)</MudSelectItem>
                    }
                </MudSelect>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@ReloadBannedAttempts">Refresh</MudButton>
            </MudStack>
            <MudTable FixedHeader="true"
                      @bind-RowsPerPage="@_bannedRowsPerPage"
                      ServerData="@(new Func<TableState, CancellationToken, Task<TableData<AdminLoginAttemptViewModel>>>(ServerReloadBannedAttempts))"
                      Dense="true"
                      Class="mb-8"
                      @ref="_bannedAttemptsTable">
                <HeaderContent>
                    <MudTh>Timestamp</MudTh>
                    <MudTh>IPv4</MudTh>
                    <MudTh>IPv6</MudTh>
                    <MudTh>Type</MudTh>
                    <MudTh>Path</MudTh>
                    <MudTh>Username</MudTh>
                    <MudTh>Location</MudTh>
                    <MudTh>Result</MudTh>
                    <MudTh>Reason</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Timestamp.ToLocalTime().ToString("G", _dtf)</MudTd>
                    <MudTd>@FormatIp(context.IpAddressV4)</MudTd>
                    <MudTd>@FormatIp(context.IpAddressV6)</MudTd>
                    <MudTd>@FormatAttemptKind(context.AttemptKind)</MudTd>
                    <MudTd>@FormatPath(context.RequestPath)</MudTd>
                    <MudTd>@FormatUsername(context.Username)</MudTd>
                    <MudTd>
                        @if (context.Latitude.HasValue && context.Longitude.HasValue)
                        {
                            <MudLink Href="@AdminLoginGeolocationHelper.BuildMapsUrl(context.Latitude, context.Longitude)"
                                     Target="_blank">
                                @AdminLoginGeolocationHelper.FormatDisplay(context.Latitude, context.Longitude)
                            </MudLink>
                        }
                        else
                        {
                            @("—")
                        }
                    </MudTd>
                    <MudTd>
                        @if (context.AttemptKind == AdminLoginAttemptKind.LoginPage)
                        {
                            <MudChip T="string" Color="Color.Info" Size="Size.Small">View</MudChip>
                        }
                        else if (context.Success)
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small">Success</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Error" Size="Size.Small">Failed</MudChip>
                        }
                    </MudTd>
                    <MudTd>@context.DenyReason</MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText>No activity from banned IP addresses yet.</MudText>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager/>
                </PagerContent>
            </MudTable>

            <MudDivider Class="mb-6"/>
            <MudText Typo="Typo.h6" Class="mb-4">Login &amp; Access Attempts</MudText>
            <MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">
                Activity is grouped by IP address. Banned IP addresses are excluded here and shown under Banned IP Activity above.
            </MudText>
            <MudTable FixedHeader="true"
                      @bind-RowsPerPage="@_activeSummaryRowsPerPage"
                      ServerData="@(new Func<TableState, CancellationToken, Task<TableData<AdminLoginIpSummaryViewModel>>>(ServerReloadActiveIpSummaries))"
                      Dense="true"
                      Class="mb-4"
                      @ref="_activeIpSummariesTable">
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel T="AdminLoginIpSummaryViewModel" SortLabel="IpAddressV4">IPv4</MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel T="AdminLoginIpSummaryViewModel" SortLabel="IpAddressV6">IPv6</MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel T="AdminLoginIpSummaryViewModel" SortLabel="Views">Views</MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel T="AdminLoginIpSummaryViewModel" SortLabel="Logins">Logins</MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel T="AdminLoginIpSummaryViewModel" SortLabel="Access">Access</MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel T="AdminLoginIpSummaryViewModel" SortLabel="Success">Success</MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel T="AdminLoginIpSummaryViewModel" SortLabel="Failed">Failed</MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel T="AdminLoginIpSummaryViewModel" SortLabel="Total">Total</MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel T="AdminLoginIpSummaryViewModel" SortLabel="LastActivity">Last Seen</MudTableSortLabel>
                    </MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@FormatIp(context.IpAddressV4)</MudTd>
                    <MudTd>@FormatIp(context.IpAddressV6)</MudTd>
                    <MudTd>@context.PageViewCount</MudTd>
                    <MudTd>@context.LoginAttemptCount</MudTd>
                    <MudTd>@context.AccessDeniedCount</MudTd>
                    <MudTd>@context.SuccessCount</MudTd>
                    <MudTd>@context.FailedCount</MudTd>
                    <MudTd>@context.TotalActivityCount</MudTd>
                    <MudTd>@FormatLastActivity(context.LastActivityAt)</MudTd>
                    <MudTd>
                        <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small"
                                   OnClick="@(_ => ShowActiveActivity(context.IpAddress))">Activity</MudButton>
                        @if (_settings.AbuseIpDbAvailable)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small"
                                       OnClick="@(_ => ShowAbuseIpDbReport(context.IpAddress))">AbuseIPDB</MudButton>
                        }
                        @if (CanBan(context.IpAddress))
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(_ => BanFromAttempt(context.IpAddress))">Ban</MudButton>
                        }
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText>No login attempts recorded yet.</MudText>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager/>
                </PagerContent>
            </MudTable>

            @if (_settings.AbuseIpDbAvailable)
            {
                <MudText Typo="Typo.subtitle1" Class="mb-2 mt-4">AbuseIPDB Report</MudText>
                @if (string.IsNullOrWhiteSpace(_abuseIpDbIp))
                {
                    <MudText Typo="Typo.body2" Class="mb-8 mud-text-secondary">
                        Click <strong>AbuseIPDB</strong> on an IP above to view its AbuseIPDB report.
                    </MudText>
                }
                else
                {
                    <MudStack Row="true" Spacing="2" Class="mb-4">
                        <MudText Typo="Typo.body1">@FormatAbuseIpDbTarget(_abuseIpDbIp)</MudText>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@ReloadAbuseIpDbReport">Refresh</MudButton>
                        <MudButton Variant="Variant.Text" OnClick="@ClearAbuseIpDbReport">Clear</MudButton>
                    </MudStack>
                    @if (_abuseIpDbLoading)
                    {
                        <MudProgressLinear Indeterminate="true" Class="mb-8"/>
                    }
                    else if (_abuseIpDbReport?.LookupPerformed != true)
                    {
                        <MudAlert Severity="Severity.Warning" Class="mb-8" Variant="Variant.Outlined">
                            @(_abuseIpDbReport?.ErrorMessage ?? "Unable to load AbuseIPDB report.")
                        </MudAlert>
                    }
                    else
                    {
                        <MudPaper Class="pa-4 mb-8" Elevation="1">
                            <MudStack Row="true" Spacing="2" Class="mb-4">
                                <MudChip T="string" Color="@GetAbuseScoreColor(_abuseIpDbReport.AbuseConfidenceScore)" Size="Size.Small">
                                    Score: @_abuseIpDbReport.AbuseConfidenceScore%
                                </MudChip>
                                @if (_abuseIpDbReport.WouldBlock)
                                {
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small">Would Block</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small">Below Threshold (@_abuseIpDbReport.MinScoreThreshold%)</MudChip>
                                }
                                @if (_abuseIpDbReport.IsWhitelisted)
                                {
                                    <MudChip T="string" Color="Color.Info" Size="Size.Small">Whitelisted</MudChip>
                                }
                            </MudStack>
                            <MudSimpleTable Dense="true" Hover="true" Bordered="true" Style="overflow-x: auto;">
                                <tbody>
                                <tr><td>Queried IP</td><td>@_abuseIpDbReport.QueriedIpAddress</td></tr>
                                <tr><td>Country</td><td>@FormatAbuseField(_abuseIpDbReport.CountryName, _abuseIpDbReport.CountryCode)</td></tr>
                                <tr><td>ISP</td><td>@FormatAbuseField(_abuseIpDbReport.Isp)</td></tr>
                                <tr><td>Domain</td><td>@FormatAbuseField(_abuseIpDbReport.Domain)</td></tr>
                                <tr><td>Usage Type</td><td>@FormatAbuseField(_abuseIpDbReport.UsageType)</td></tr>
                                <tr><td>Total Reports</td><td>@_abuseIpDbReport.TotalReports</td></tr>
                                <tr><td>Distinct Reporters</td><td>@_abuseIpDbReport.NumDistinctUsers</td></tr>
                                <tr><td>Last Reported</td><td>@FormatLastReported(_abuseIpDbReport.LastReportedAt)</td></tr>
                                <tr><td>Public IP</td><td>@(_abuseIpDbReport.IsPublic ? "Yes" : "No")</td></tr>
                                <tr><td>IP Version</td><td>@(_abuseIpDbReport.IpVersion == 0 ? "—" : _abuseIpDbReport.IpVersion.ToString())</td></tr>
                                <tr>
                                    <td>AbuseIPDB</td>
                                    <td>
                                        <MudLink Href="@_abuseIpDbReport.AbuseIpDbUrl" Target="_blank">View on AbuseIPDB</MudLink>
                                    </td>
                                </tr>
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                    }
                }
            }

            <MudText Typo="Typo.subtitle1" Class="mb-2">Login IP Activity</MudText>
            <MudStack Row="true" Spacing="2" Class="mb-4">
                <MudSelect T="string" Value="@_activeIpFilter" ValueChanged="OnActiveIpFilterChanged" Label="Filter by IP" Style="max-width: 280px" Clearable="true">
                    @foreach (AdminLoginIpSummaryViewModel summary in _activeIpFilterOptions)
                    {
                        <MudSelectItem T="string" Value="@summary.IpAddress">@FormatIp(summary.IpAddressV4) / @FormatIp(summary.IpAddressV6)</MudSelectItem>
                    }
                </MudSelect>
                <MudTextField @bind-Value="_searchString" Label="Search username, path, or reason" Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search" Style="max-width: 320px"/>
                <MudSelect T="AdminLoginAttemptKind?" @bind-Value="_attemptKindFilter" Label="Type" Style="max-width: 200px">
                    <MudSelectItem T="AdminLoginAttemptKind?" Value="@((AdminLoginAttemptKind?)null)">All</MudSelectItem>
                    <MudSelectItem T="AdminLoginAttemptKind?" Value="@AdminLoginAttemptKind.Login">Login</MudSelectItem>
                    <MudSelectItem T="AdminLoginAttemptKind?" Value="@AdminLoginAttemptKind.LoginPage">Login Page</MudSelectItem>
                    <MudSelectItem T="AdminLoginAttemptKind?" Value="@AdminLoginAttemptKind.AccessDenied">Access Denied</MudSelectItem>
                </MudSelect>
                <MudSelect T="bool?" @bind-Value="_successFilter" Label="Result" Style="max-width: 180px">
                    <MudSelectItem T="bool?" Value="@((bool?)null)">All</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@true">Success</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@false">Failed</MudSelectItem>
                </MudSelect>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@ReloadAttempts">Search</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@ReloadActiveIpSummaries">Refresh</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="@(_ => _showClearLogConfirm = true)">Clear Log</MudButton>
            </MudStack>
            @if (_showClearLogConfirm)
            {
                <MudAlert Severity="Severity.Warning" Class="mb-4" Variant="Variant.Outlined">
                    <MudText Typo="Typo.body2" Class="mb-3">
                        Permanently delete all entries in Login &amp; Access Attempts? Banned IP activity is not affected.
                    </MudText>
                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="@ClearAttemptsLog">Confirm Clear</MudButton>
                        <MudButton Variant="Variant.Outlined" OnClick="@(_ => _showClearLogConfirm = false)">Cancel</MudButton>
                    </MudStack>
                </MudAlert>
            }
            <MudTable FixedHeader="true"
                      @bind-RowsPerPage="@_rowsPerPage"
                      ServerData="@(new Func<TableState, CancellationToken, Task<TableData<AdminLoginAttemptViewModel>>>(ServerReloadAttempts))"
                      Dense="true"
                      @ref="_attemptsTable">
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel T="AdminLoginAttemptViewModel" SortLabel="Timestamp">Timestamp</MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel T="AdminLoginAttemptViewModel" SortLabel="IpAddressV4">IPv4</MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel T="AdminLoginAttemptViewModel" SortLabel="IpAddressV6">IPv6</MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel T="AdminLoginAttemptViewModel" SortLabel="AttemptKind">Type</MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel T="AdminLoginAttemptViewModel" SortLabel="RequestPath">Path</MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel T="AdminLoginAttemptViewModel" SortLabel="Username">Username</MudTableSortLabel>
                    </MudTh>
                    <MudTh>Location</MudTh>
                    <MudTh>
                        <MudTableSortLabel T="AdminLoginAttemptViewModel" SortLabel="Success">Result</MudTableSortLabel>
                    </MudTh>
                    <MudTh>Reason</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Timestamp.ToLocalTime().ToString("G", _dtf)</MudTd>
                    <MudTd>@FormatIp(context.IpAddressV4)</MudTd>
                    <MudTd>@FormatIp(context.IpAddressV6)</MudTd>
                    <MudTd>@FormatAttemptKind(context.AttemptKind)</MudTd>
                    <MudTd>@FormatPath(context.RequestPath)</MudTd>
                    <MudTd>@FormatUsername(context.Username)</MudTd>
                    <MudTd>
                        @if (context.Latitude.HasValue && context.Longitude.HasValue)
                        {
                            <MudLink Href="@AdminLoginGeolocationHelper.BuildMapsUrl(context.Latitude, context.Longitude)"
                                     Target="_blank">
                                @AdminLoginGeolocationHelper.FormatDisplay(context.Latitude, context.Longitude)
                            </MudLink>
                        }
                        else
                        {
                            @("—")
                        }
                    </MudTd>
                    <MudTd>
                        @if (context.AttemptKind == AdminLoginAttemptKind.LoginPage)
                        {
                            <MudChip T="string" Color="Color.Info" Size="Size.Small">View</MudChip>
                        }
                        else if (context.Success)
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small">Success</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Error" Size="Size.Small">Failed</MudChip>
                        }
                    </MudTd>
                    <MudTd>@context.DenyReason</MudTd>
                    <MudTd>
                        @if (CanBan(context.IpAddress))
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(_ => BanFromAttempt(context.IpAddress))">Ban</MudButton>
                        }
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    @if (string.IsNullOrWhiteSpace(_activeIpFilter))
                    {
                        <MudText>Select Activity on an IP above, or choose an IP from the filter.</MudText>
                    }
                    else
                    {
                        <MudText>No activity recorded for this IP.</MudText>
                    }
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager/>
                </PagerContent>
            </MudTable>
        </MudContainer>
    </div>
</MudForm>

@code {
    private CancellationTokenSource _cts;
    private readonly DateTimeFormatInfo _dtf = CultureInfo.CurrentCulture.DateTimeFormat;

    private LoginIpSettingsViewModel _settings = new();
    private List<AdminIpRuleViewModel> _whitelistRules = [];
    private List<AdminIpRuleViewModel> _blacklistRules = [];
    private MudTable<AdminLoginAttemptViewModel> _attemptsTable;
    private MudTable<AdminLoginAttemptViewModel> _bannedAttemptsTable;
    private MudTable<AdminLoginIpSummaryViewModel> _activeIpSummariesTable;
    private int _rowsPerPage = 10;
    private int _bannedRowsPerPage = 10;
    private int _activeSummaryRowsPerPage = 10;
    private string _searchString;
    private string _bannedIpFilter;
    private string _activeIpFilter;
    private List<AdminLoginIpSummaryViewModel> _activeIpFilterOptions = [];
    private bool _showClearLogConfirm;
    private bool? _successFilter;
    private AdminLoginAttemptKind? _attemptKindFilter;
    private string _newWhitelistIp;
    private string _newWhitelistNote;
    private string _newBlacklistIp;
    private string _newBlacklistNote;
    private string _abuseIpDbIp;
    private AbuseIpDbReportViewModel _abuseIpDbReport;
    private bool _abuseIpDbLoading;
    private bool _refreshingBlocklists;
    private string _newCustomBlocklistName;
    private string _newCustomBlocklistUrl;
    private PublicBlocklistFormat _newCustomBlocklistFormat = PublicBlocklistFormat.Mixed;
    private int _newCustomBlocklistUpdateHours = 24;

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }

    protected override async Task OnParametersSetAsync()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        try
        {
            _settings = await Mediator.Send(new GetLoginIpSettings(), token);
            _rowsPerPage = await Mediator.Send(new GetConfigElementByKey(ConfigElementKey.LoginIpAttemptsPageSize), token)
                .Map(maybeRows => maybeRows.Match(ce => int.TryParse(ce.Value, out int rows) ? rows : 10, () => 10));
            await LoadRules(token);
            await LoadActiveIpFilterOptions(token);
        }
        catch (OperationCanceledException)
        {
            // do nothing
        }
    }

    private async Task LoadRules(CancellationToken token)
    {
        _whitelistRules = await Mediator.Send(new GetAdminIpRules(AdminIpRuleType.Whitelist), token);
        _blacklistRules = await Mediator.Send(new GetAdminIpRules(AdminIpRuleType.Blacklist), token);
    }

    private async Task LoadActiveIpFilterOptions(CancellationToken token)
    {
        PagedAdminLoginIpSummariesViewModel data =
            await Mediator.Send(new GetAdminLoginIpSummaries(0, 10000, null), token);
        _activeIpFilterOptions = data.Page;
    }

    private async Task SaveSettings()
    {
        Either<BaseError, Unit> result = await Mediator.Send(new UpdateLoginIpSettings(_settings), _cts.Token);
        result.Match(
            Left: error =>
            {
                Snackbar.Add(error.Value, Severity.Error);
                Logger.LogError("Failed to save login IP settings: {Error}", error.Value);
            },
            Right: _ => Snackbar.Add("Successfully saved login IP settings", Severity.Success));
    }

    private void EnableRecommendedBlocklists()
    {
        foreach (PublicBlocklistItemViewModel item in _settings.PublicBlocklists.Where(item => item.Recommended))
        {
            item.Enabled = true;
        }

        _settings.PublicBlocklistsMasterEnabled = true;
    }

    private void AddCustomBlocklist()
    {
        if (_settings.PublicBlocklists.Count(item => item.IsCustom) >= PublicBlocklistRegistry.MaxCustomLists)
        {
            Snackbar.Add($"You can add at most {PublicBlocklistRegistry.MaxCustomLists} custom blocklists.", Severity.Error);
            return;
        }

        var entry = new CustomPublicBlocklistEntry
        {
            Name = _newCustomBlocklistName,
            SourceUrl = _newCustomBlocklistUrl,
            Format = _newCustomBlocklistFormat,
            UpdateIntervalHours = _newCustomBlocklistUpdateHours
        };

        Option<BaseError> validation = PublicBlocklistValidation.ValidateCustomEntry(entry);
        foreach (BaseError error in validation)
        {
            Snackbar.Add(error.Value, Severity.Error);
            return;
        }

        if (_settings.PublicBlocklists.Any(item =>
                item.IsCustom &&
                string.Equals(item.SourceUrl.Trim(), entry.SourceUrl.Trim(), StringComparison.OrdinalIgnoreCase)))
        {
            Snackbar.Add("That URL is already in your custom blocklists.", Severity.Error);
            return;
        }

        PublicBlocklistDefinition definition = entry.ToDefinition();
        _settings.PublicBlocklists.Add(new PublicBlocklistItemViewModel
        {
            Id = definition.Id,
            Name = definition.Name,
            Category = definition.Category,
            Description = definition.Description,
            SourceLabel = definition.SourceLabel,
            SourceUrl = definition.SourceUrl,
            Format = definition.Format,
            UpdateIntervalHours = _newCustomBlocklistUpdateHours,
            IsCustom = true,
            Enabled = true
        });

        _newCustomBlocklistName = string.Empty;
        _newCustomBlocklistUrl = string.Empty;
        _newCustomBlocklistFormat = PublicBlocklistFormat.Mixed;
        _newCustomBlocklistUpdateHours = 24;
        Snackbar.Add("Custom blocklist added. Click Save Settings to download it.", Severity.Success);
    }

    private void RemoveCustomBlocklist(string id)
    {
        PublicBlocklistItemViewModel item =
            _settings.PublicBlocklists.FirstOrDefault(entry => entry.IsCustom && entry.Id == id);
        if (item is null)
        {
            return;
        }

        _settings.PublicBlocklists.Remove(item);
        Snackbar.Add("Custom blocklist removed. Click Save Settings to apply.", Severity.Info);
    }

    private async Task RefreshPublicBlocklists()
    {
        _refreshingBlocklists = true;
        try
        {
            await Mediator.Send(new RefreshPublicBlocklists(), _cts.Token);
            _settings = await Mediator.Send(new GetLoginIpSettings(), _cts.Token);
            Snackbar.Add("Public blocklists refreshed", Severity.Success);
        }
        catch (OperationCanceledException)
        {
            // do nothing
        }
        finally
        {
            _refreshingBlocklists = false;
        }
    }

    private static string FormatBlocklistEntries(PublicBlocklistItemViewModel item) =>
        item.NetworkCount > 0
            ? $"{item.EntryCount:N0} IPs, {item.NetworkCount:N0} networks"
            : $"{item.EntryCount:N0} IPs";

    private static string FormatBlocklistUpdated(DateTimeOffset? lastUpdatedUtc) =>
        lastUpdatedUtc?.ToLocalTime().ToString("g", CultureInfo.CurrentCulture.DateTimeFormat) ?? "Pending";

    private static string FormatBlocklistStatus(PublicBlocklistItemViewModel item)
    {
        if (item.IsUpdating)
        {
            return "Updating";
        }

        if (!string.IsNullOrWhiteSpace(item.LastError))
        {
            return item.LastError;
        }

        return item.EntryCount > 0 || item.NetworkCount > 0 ? "Ready" : "Waiting for first update";
    }

    private static string FormatBlocklistFormat(PublicBlocklistFormat format) =>
        format == PublicBlocklistFormat.IpAddress ? "IPs only" : "IPs and CIDRs";

    private async Task AddRule(AdminIpRuleType ruleType)
    {
        string ip = ruleType == AdminIpRuleType.Whitelist ? _newWhitelistIp : _newBlacklistIp;
        string note = ruleType == AdminIpRuleType.Whitelist ? _newWhitelistNote : _newBlacklistNote;

        Either<BaseError, Unit> result = await Mediator.Send(new AddAdminIpRule(ip, ruleType, note), _cts.Token);
        if (result.IsLeft)
        {
            Snackbar.Add(result.LeftAsEnumerable().First().Value, Severity.Error);
            return;
        }

        Snackbar.Add(ruleType == AdminIpRuleType.Whitelist ? "Added to whitelist" : "IP banned", Severity.Success);
        if (ruleType == AdminIpRuleType.Whitelist)
        {
            _newWhitelistIp = string.Empty;
            _newWhitelistNote = string.Empty;
        }
        else
        {
            _newBlacklistIp = string.Empty;
            _newBlacklistNote = string.Empty;
        }

        await LoadRules(_cts.Token);
        if (ruleType == AdminIpRuleType.Blacklist)
        {
            await ReloadBannedAttempts();
            await ReloadActiveIpSummaries();
            await ReloadAttempts();
        }
    }

    private async Task RemoveRule(int id)
    {
        Either<BaseError, Unit> result = await Mediator.Send(new RemoveAdminIpRule(id), _cts.Token);
        if (result.IsLeft)
        {
            Snackbar.Add(result.LeftAsEnumerable().First().Value, Severity.Error);
            return;
        }

        await LoadRules(_cts.Token);
        await ReloadBannedAttempts();
    }

    private async Task Unban(string ipAddress)
    {
        Either<BaseError, Unit> result = await Mediator.Send(new UnbanIpAddress(ipAddress), _cts.Token);
        if (result.IsLeft)
        {
            Snackbar.Add(result.LeftAsEnumerable().First().Value, Severity.Error);
            return;
        }

        Snackbar.Add("IP unbanned", Severity.Success);
        if (string.Equals(_bannedIpFilter, ipAddress, StringComparison.OrdinalIgnoreCase))
        {
            _bannedIpFilter = null;
        }

        await LoadRules(_cts.Token);
        await LoadActiveIpFilterOptions(_cts.Token);
        await ReloadBannedAttempts();
        await ReloadActiveIpSummaries();
        await ReloadAttempts();
    }

    private async Task BanFromAttempt(string ipAddress)
    {
        Either<BaseError, Unit> result =
            await Mediator.Send(new BanIpAddress(ipAddress, "Banned from login attempts"), _cts.Token);
        if (result.IsLeft)
        {
            Snackbar.Add(result.LeftAsEnumerable().First().Value, Severity.Error);
            return;
        }

        Snackbar.Add("IP banned", Severity.Success);
        if (string.Equals(_activeIpFilter, ipAddress, StringComparison.OrdinalIgnoreCase))
        {
            _activeIpFilter = null;
        }

        await LoadRules(_cts.Token);
        await LoadActiveIpFilterOptions(_cts.Token);
        await ReloadBannedAttempts();
        await ReloadActiveIpSummaries();
        await ReloadAttempts();
    }

    private async Task ShowBannedActivity(string ipAddress)
    {
        _bannedIpFilter = ipAddress;
        await ReloadBannedAttempts();
    }

    private async Task ShowActiveActivity(string ipAddress)
    {
        _activeIpFilter = ipAddress;
        await ReloadAttempts();
    }

    private async Task ShowAbuseIpDbReport(string ipAddress)
    {
        _abuseIpDbIp = ipAddress;
        await LoadAbuseIpDbReport();
    }

    private async Task ReloadAbuseIpDbReport()
    {
        if (!string.IsNullOrWhiteSpace(_abuseIpDbIp))
        {
            await LoadAbuseIpDbReport();
        }
    }

    private void ClearAbuseIpDbReport()
    {
        _abuseIpDbIp = null;
        _abuseIpDbReport = null;
        _abuseIpDbLoading = false;
    }

    private async Task LoadAbuseIpDbReport()
    {
        if (string.IsNullOrWhiteSpace(_abuseIpDbIp))
        {
            return;
        }

        _abuseIpDbLoading = true;
        try
        {
            _abuseIpDbReport = await Mediator.Send(new GetAbuseIpDbReport(_abuseIpDbIp), _cts.Token);
        }
        catch (OperationCanceledException)
        {
            // do nothing
        }
        finally
        {
            _abuseIpDbLoading = false;
        }
    }

    private async Task OnActiveIpFilterChanged(string ipAddress)
    {
        _activeIpFilter = ipAddress;
        await ReloadAttempts();
    }

    private bool IsBlacklisted(string ipAddress) =>
        _blacklistRules.Any(r => string.Equals(r.IpAddress, ipAddress, StringComparison.OrdinalIgnoreCase));

    private bool CanBan(string ipAddress) =>
        !string.IsNullOrWhiteSpace(ipAddress) &&
        !IsBlacklisted(ipAddress) &&
        !ProtectedIpExemption.IsExempt(ipAddress);

    private static string FormatIp(string ip) =>
        string.IsNullOrWhiteSpace(ip) ? "—" : ip;

    private static string FormatPath(string path) =>
        string.IsNullOrWhiteSpace(path) ? "—" : path;

    private static string FormatUsername(string username) =>
        string.IsNullOrWhiteSpace(username) ? "—" : username;

    private static string FormatAttemptKind(AdminLoginAttemptKind kind) =>
        kind switch
        {
            AdminLoginAttemptKind.Login => "Login",
            AdminLoginAttemptKind.LoginPage => "Login Page",
            AdminLoginAttemptKind.AccessDenied => "Access Denied",
            _ => kind.ToString()
        };

    private static string FormatLastActivity(DateTime? lastActivityAt) =>
        lastActivityAt?.ToLocalTime().ToString("g", CultureInfo.CurrentCulture.DateTimeFormat) ?? "—";

    private static string FormatAbuseField(string value, string suffix = null)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "—";
        }

        return string.IsNullOrWhiteSpace(suffix) ? value : $"{value} ({suffix})";
    }

    private static string FormatLastReported(DateTimeOffset? lastReportedAt) =>
        lastReportedAt?.ToLocalTime().ToString("G", CultureInfo.CurrentCulture.DateTimeFormat) ?? "—";

    private static string FormatAbuseIpDbTarget(string ipAddress)
    {
        IpAddressPair pair = IpAddressFormatting.FromString(ipAddress);
        string v4 = FormatIp(pair.Ipv4);
        string v6 = FormatIp(pair.Ipv6);
        return v4 == "—" && v6 == "—" ? ipAddress : $"{v4} / {v6}";
    }

    private static Color GetAbuseScoreColor(int score) =>
        score switch
        {
            >= 75 => Color.Error,
            >= 50 => Color.Warning,
            _ => Color.Success
        };

    private async Task ReloadAttempts()
    {
        if (_attemptsTable is not null)
        {
            await _attemptsTable.ReloadServerData();
        }
    }

    private async Task ClearAttemptsLog()
    {
        Either<BaseError, int> result =
            await Mediator.Send(new ClearAdminLoginAttempts(LoginAttemptScope.Active), _cts.Token);

        _showClearLogConfirm = false;

        if (result.IsLeft)
        {
            Snackbar.Add(result.LeftAsEnumerable().First().Value, Severity.Error);
            return;
        }

        int deleted = result.RightToSeq().First();
        Snackbar.Add(
            deleted == 0 ? "Login log is already empty." : $"Cleared {deleted} log entries.",
            Severity.Success);
        await LoadActiveIpFilterOptions(_cts.Token);
        await ReloadActiveIpSummaries();
        await ReloadAttempts();
    }

    private async Task ReloadActiveIpSummaries()
    {
        if (_activeIpSummariesTable is not null)
        {
            await _activeIpSummariesTable.ReloadServerData();
        }

        await LoadActiveIpFilterOptions(_cts.Token);
    }

    private async Task<TableData<AdminLoginIpSummaryViewModel>> ServerReloadActiveIpSummaries(
        TableState state,
        CancellationToken cancellationToken)
    {
        GetAdminLoginIpSummaries query = new(
            state.Page,
            state.PageSize,
            null,
            state.SortLabel?.ToLowerInvariant() ?? "lastactivity",
            state.SortDirection == SortDirection.None || state.SortDirection == SortDirection.Descending);

        PagedAdminLoginIpSummariesViewModel data = await Mediator.Send(query, cancellationToken);
        return new TableData<AdminLoginIpSummaryViewModel> { TotalItems = data.TotalCount, Items = data.Page };
    }

    private async Task<TableData<AdminLoginAttemptViewModel>> ServerReloadAttempts(
        TableState state,
        CancellationToken cancellationToken)
    {
        if (string.IsNullOrWhiteSpace(_activeIpFilter))
        {
            return new TableData<AdminLoginAttemptViewModel> { TotalItems = 0, Items = [] };
        }

        await Mediator.Send(
            new SaveConfigElementByKey(ConfigElementKey.LoginIpAttemptsPageSize, state.PageSize.ToString()),
            cancellationToken);

        GetAdminLoginAttempts query = new(
            state.Page,
            state.PageSize,
            _searchString,
            _successFilter,
            _attemptKindFilter,
            state.SortLabel?.ToLowerInvariant() ?? "timestamp",
            state.SortDirection == SortDirection.None || state.SortDirection == SortDirection.Descending,
            LoginAttemptScope.Active,
            _activeIpFilter);

        PagedAdminLoginAttemptsViewModel data = await Mediator.Send(query, cancellationToken);
        return new TableData<AdminLoginAttemptViewModel> { TotalItems = data.TotalCount, Items = data.Page };
    }

    private async Task ReloadBannedAttempts()
    {
        if (_bannedAttemptsTable is not null)
        {
            await _bannedAttemptsTable.ReloadServerData();
        }
    }

    private async Task<TableData<AdminLoginAttemptViewModel>> ServerReloadBannedAttempts(
        TableState state,
        CancellationToken cancellationToken)
    {
        GetAdminLoginAttempts query = new(
            state.Page,
            state.PageSize,
            null,
            null,
            null,
            "timestamp",
            true,
            LoginAttemptScope.Banned,
            _bannedIpFilter);

        PagedAdminLoginAttemptsViewModel data = await Mediator.Send(query, cancellationToken);
        return new TableData<AdminLoginAttemptViewModel> { TotalItems = data.TotalCount, Items = data.Page };
    }
}
